# URL base do Lovable Cloud (produção)
# Ex.: https://project--<project-id>.lovable.app
LOVABLE_APP_URL=

# Mesmo valor do secret SCRAPER_WORKER_SHARED_SECRET no Lovable Cloud
SCRAPER_WORKER_SHARED_SECRET=

# Polling interval (ms) entre chamadas /claim quando não há job
POLL_INTERVAL_MS=15000

# Delay entre questões (ms) para não pisar em rate-limit
QUESTION_DELAY_MS=2000

# Opcional: Firecrawl como fallback de extração
FIRECRAWL_API_KEY=
